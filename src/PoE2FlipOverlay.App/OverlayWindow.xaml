<Window x:Class="PoE2FlipOverlay.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PoE2 Flip Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Left="60" Top="60"
        FontFamily="Segoe UI">

    <StackPanel Orientation="Horizontal">

    <!-- Mini history (left of the main panel) -->
    <Border Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
            CornerRadius="10" Padding="12" Margin="0,0,10,0"
            Width="184" VerticalAlignment="Top">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="histórico" Foreground="{StaticResource Gold}"
                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock x:Name="HistoryEmpty" Text="capture um par pra registrar"
                       Foreground="{StaticResource TextFaint}" FontSize="10" TextWrapping="Wrap"/>
            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BigBackground}"
                                BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                                CornerRadius="6" Padding="8,6" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="{Binding Pair}" Foreground="{StaticResource Gold}"
                                           FontSize="11" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <Grid Margin="0,2,0,0">
                                    <TextBlock Text="{Binding BidAskText}" Foreground="{StaticResource TextPrimary}" FontSize="11"/>
                                    <TextBlock Text="{Binding MarginText}" Foreground="{StaticResource TextMuted}"
                                               FontSize="11" HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource TextFaint}"
                                           FontSize="9" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>

    <!-- Main panel -->
    <Border Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16"
            MinWidth="260">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,10">
                <TextBlock x:Name="HeaderTitle" Text="⚖ Flip — Fracturing × Divine"
                           Foreground="{StaticResource Gold}"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse x:Name="ModeIndicator"
                             Width="10" Height="10" Margin="0,0,10,0"
                             VerticalAlignment="Center"
                             Fill="{StaticResource TextFaint}"
                             ToolTip="Cinza: click-through (cliques passam pro jogo). Verde: modo interativo."/>
                    <Button Content="✕" Click="OnCloseClick"
                            Foreground="{StaticResource TextMuted}"
                            Background="Transparent" BorderThickness="0"
                            FontSize="13" Padding="4,0" Cursor="Hand"
                            ToolTip="Fechar (só clicável no modo interativo — Ctrl+Shift+F)"/>
                </StackPanel>
            </Grid>

            <!-- BUY -->
            <Border Background="{StaticResource BigBackground}"
                    BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                <Grid>
                    <TextBlock Text="COMPRAR a" Foreground="{StaticResource TextMuted}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="BuyPrice" Text="—"
                               Foreground="{StaticResource Gold}"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- SELL -->
            <Border Background="{StaticResource BigBackground}"
                    BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
                <Grid>
                    <TextBlock Text="VENDER a" Foreground="{StaticResource TextMuted}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SellPrice" Text="—"
                               Foreground="{StaticResource Gold}"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- bid / ask read -->
            <Grid Margin="0,0,0,6">
                <TextBlock Text="bid / ask lidos" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                <TextBlock x:Name="BookRead" Text="—" Foreground="{StaticResource TextPrimary}"
                           FontSize="12" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Budget input (editable in interactive mode) -->
            <Grid Margin="0,0,0,4">
                <TextBlock Text="divines que tenho" Foreground="{StaticResource TextMuted}"
                           FontSize="12" VerticalAlignment="Center"/>
                <TextBox x:Name="BudgetInput" Width="84" HorizontalAlignment="Right"
                         HorizontalContentAlignment="Right"
                         Background="#12100E" Foreground="{StaticResource TextPrimary}"
                         BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                         CaretBrush="{StaticResource Gold}" Padding="4,2"
                         TextChanged="OnBudgetChanged"/>
            </Grid>

            <!-- Placeable whole-orb orders, scaled to the budget -->
            <Separator Margin="0,6,0,4" Background="{StaticResource PanelBorder}"/>
            <TextBlock Text="ordens a colocar (orbs inteiros)"
                       Foreground="{StaticResource TextFaint}" FontSize="10" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,3">
                <TextBlock Text="COMPRA" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                <TextBlock x:Name="BuyOrder" Text="—" Foreground="{StaticResource Gold}"
                           FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,0,0,6">
                <TextBlock Text="VENDA" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                <TextBlock x:Name="SellOrder" Text="—" Foreground="{StaticResource Gold}"
                           FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0,0,0,2">
                <TextBlock Text="lucro do ciclo" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                <TextBlock x:Name="Profit" Text="—" Foreground="{StaticResource ProfitPos}"
                           FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,0,0,2">
                <TextBlock Text="margem" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                <TextBlock x:Name="MarginValue" Text="—" Foreground="{StaticResource TextPrimary}"
                           FontSize="12" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Warning -->
            <Border x:Name="WarningBox" Visibility="Collapsed"
                    CornerRadius="6" Padding="8,6" Margin="0,8,0,0"
                    Background="#2E2816" BorderBrush="#6E5C28" BorderThickness="1">
                <TextBlock x:Name="WarningText" Text="" Foreground="#E8D496"
                           FontSize="11" TextWrapping="Wrap"/>
            </Border>

            <!-- Calibrate button (clickable in interactive mode) -->
            <Button x:Name="CalibrateButton" Content="⚙ calibrar região do painel"
                    Click="OnCalibrateClick"
                    Foreground="{StaticResource TextMuted}" Background="Transparent"
                    BorderThickness="0" FontSize="11" Cursor="Hand"
                    Margin="0,10,0,0" HorizontalAlignment="Center"/>

            <!-- Hotkey hint -->
            <TextBlock x:Name="HintText"
                       Text="Ctrl+Shift+F: mover/editar · Ctrl+Shift+X: sair"
                       Foreground="{StaticResource TextFaint}"
                       FontSize="10" Margin="0,10,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>

    </StackPanel>
</Window>
